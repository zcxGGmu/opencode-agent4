{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RootCauseBlueprint",
  "type": "object",
  "required": [
    "schemaVersion",
    "blueprintId",
    "source",
    "problem",
    "rootCause",
    "constraints",
    "validation"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "ysclaw.root_cause_blueprint.v1"
    },
    "blueprintId": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "agent",
        "createdAt"
      ],
      "additionalProperties": false,
      "properties": {
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "minLength": 1
        },
        "software": {
          "type": "string"
        },
        "testcaseIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "problem": {
      "type": "object",
      "required": [
        "summary",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rootCause": {
      "type": "object",
      "required": [
        "summary",
        "candidateFiles",
        "performanceFactors"
      ],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "candidateFiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "performanceFactors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "required": [
        "riskLevel",
        "mustPreserve"
      ],
      "additionalProperties": false,
      "properties": {
        "riskLevel": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "mustPreserve": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "requiredTests"
      ],
      "additionalProperties": false,
      "properties": {
        "requiredTests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "regressionCommand": {
          "type": "string",
          "pattern": "^agent1[ \\t]+patch_regression(?:[ \\t]+[A-Za-z0-9_./:=,\\-]+)*$"
        }
      }
    }
  }
}
