{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "候选补丁",
  "type": "object",
  "required": [
    "schemaVersion",
    "patchCandidateId",
    "patchPlanId",
    "createdAt",
    "changedFiles",
    "gitDiff",
    "buildModeInvocation",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "ysclaw.patch_candidate.v1"
    },
    "patchCandidateId": {
      "type": "string",
      "minLength": 1
    },
    "patchPlanId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gitDiff": {
      "type": "string",
      "minLength": 1
    },
    "buildModeInvocation": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
