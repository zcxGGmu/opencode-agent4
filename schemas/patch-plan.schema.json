{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "补丁计划",
  "type": "object",
  "required": [
    "schemaVersion",
    "patchPlanId",
    "blueprintId",
    "createdAt",
    "objective",
    "changes",
    "validationPlan",
    "expectedDiffSummary"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "ysclaw.patch_plan.v1"
    },
    "patchPlanId": {
      "type": "string",
      "minLength": 1
    },
    "blueprintId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "filePath",
          "action",
          "rationale",
          "instructions",
          "risk"
        ],
        "additionalProperties": false,
        "properties": {
          "filePath": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "enum": [
              "modify",
              "add",
              "delete"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "instructions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "risk": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "validationPlan": {
      "type": "object",
      "required": [
        "regressionTarget",
        "commands",
        "requiredTests"
      ],
      "additionalProperties": false,
      "properties": {
        "regressionTarget": {
          "type": "string",
          "minLength": 1
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^agent1[ \\t]+patch_regression(?:[ \\t]+[A-Za-z0-9_./:=,\\-]+)*$"
          }
        },
        "requiredTests": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expectedDiffSummary": {
      "type": "string",
      "minLength": 1
    }
  }
}
